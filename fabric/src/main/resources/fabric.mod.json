{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "sources": "https://github.com/fakeneko/fakeneko_config"
  },
  "license": "${license}",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "cn.com.fakeneko.config.fabric.FakenekoConfigFabric"
    ],
    "client": [
      "cn.com.fakeneko.config.fabric.FakenekoConfigFabricClient"
    ]
  },
  "mixins": [
    "${mod_id}-common.mixins.json"
  ],
  "accessWidener": "${mod_id}.accesswidener",
  "depends": {
    "fabricloader": "${fabric_loader_version}",
    "minecraft": "${minecraft_version}"
  }
}
